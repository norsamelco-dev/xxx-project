VITE_APP_THEME=theme1
# Primary API (online). Falls back to VITE_API_BASE_URL when empty.
VITE_API_ONLINE_BASE_URL=
# Fallback API when online is unreachable (e.g. local LAN server).
VITE_API_OFFLINE_BASE_URL=
# Legacy single URL — used as online when VITE_API_ONLINE_BASE_URL is empty.
VITE_API_BASE_URL=
